{
  "name": "actnow-platform",
  "version": "0.1.0",
  "private": true,
  "description": "ActNow AIGC platform monorepo.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run start:dev --workspace apps/api",
    "dev:worker": "npm run start:dev --workspace apps/worker",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace packages/db",
    "db:migrate": "npm run db:migrate --workspace packages/db",
    "db:deploy": "npm run db:deploy --workspace packages/db",
    "db:seed": "npm run db:seed --workspace packages/db"
  },
  "engines": {
    "node": ">=22"
  }
}
